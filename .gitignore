# Local terraform directory (plugins and modules)
.terraform/

# Terraform state files (contains metadata about your cloud resources)
*.tfstate
*.tfstate.backup

# Terraform configuration files that might contain secrets
*.tfvars
*.tfvars.json

# Variable override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc